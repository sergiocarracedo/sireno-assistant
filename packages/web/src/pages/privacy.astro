---
import '../styles/global.css';
import '../styles/custom.css';
import Logo from '../components/Logo.astro';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Privacy policy for Sireno Assistant. Learn how we protect your data and privacy." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Privacy Policy - Sireno Assistant</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-slate-950 text-white antialiased">
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/10">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <Logo class="w-10 h-10" color="#fff" />
            <span class="text-xl font-bold">Sireno Assistant</span>
          </a>
          <div class="hidden md:flex items-center gap-6">
            <a href="/getting-started" class="hover:text-purple-400 transition-colors">Docs</a>
            <a href="https://github.com/sergiocarracedo/sireno-assistant" target="_blank" rel="noopener" class="hover:text-purple-400 transition-colors">GitHub</a>
            <a href="https://chromewebstore.google.com/detail/ppnecnomfnadhbcpacgkfldiapoejogo" target="_blank" rel="noopener" class="bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 px-6 py-2 rounded-lg font-medium transition-all border-2 border-white">
              Install Extension
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="pt-24 pb-16">
      <div class="container mx-auto px-4 max-w-4xl">
        
        <!-- Hero -->
        <div class="mb-12 text-center">
          <div class="w-16 h-16 flex items-center justify-center bg-purple-500/20 rounded-lg mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          </div>
          <h1 class="text-5xl font-bold mb-4 gradient-text">Privacy Policy</h1>
          <p class="text-lg text-slate-400">
            Last Updated: February 9, 2026
          </p>
        </div>

        <!-- Overview -->
        <section class="mb-12">
          <div class="glass p-8 rounded-xl">
            <h2 class="text-3xl font-bold mb-4">Overview</h2>
            <p class="text-lg text-slate-300">
              Sireno Assistant is a browser extension that helps users interact with web forms using AI. <strong class="text-white">We take your privacy seriously.</strong>
            </p>
          </div>
        </section>

        <!-- Data Collection -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/></svg>
            </div>
            Data Collection
          </h2>
          <div class="bg-green-500/10 border-2 border-green-500/30 p-6 rounded-xl">
            <p class="text-lg text-green-200">
              <strong>Sireno Assistant does NOT collect, store, or transmit any personal data to our servers.</strong>
            </p>
          </div>
        </section>

        <!-- How Your Data is Handled -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">How Your Data is Handled</h2>
          
          <div class="space-y-6">
            <!-- API Keys -->
            <div class="glass p-6 rounded-xl">
              <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                API Keys
              </h3>
              <ul class="space-y-3 text-slate-300">
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>Stored locally in your browser using Chrome's storage API</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>Never transmitted to our servers</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>Only sent to your chosen AI provider (OpenAI, Anthropic, Google AI, or Groq)</div>
                </li>
              </ul>
            </div>

            <!-- Form Content -->
            <div class="glass p-6 rounded-xl">
              <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
                Form Content
              </h3>
              <ul class="space-y-3 text-slate-300">
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>Content from web forms is sent ONLY to your chosen AI provider's API</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>We do not have access to this data</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>No data is stored on our servers</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>Data handling follows your AI provider's privacy policy</div>
                </li>
              </ul>
            </div>

            <!-- Browsing Data -->
            <div class="glass p-6 rounded-xl">
              <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                Browsing Data
              </h3>
              <ul class="space-y-3 text-slate-300">
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>The extension detects form fields on websites you visit</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>This information stays in your browser</div>
                </li>
                <li class="flex gap-3">
                  <span class="text-purple-400">•</span>
                  <div>No browsing history is collected or transmitted</div>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Third-Party Services -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            Third-Party Services
          </h2>
          
          <div class="glass p-6 rounded-xl mb-4">
            <p class="text-slate-300 mb-4">
              When you use Sireno Assistant, data is sent to your chosen AI provider:
            </p>
            
            <div class="space-y-3">
              <a href="https://openai.com/privacy" target="_blank" rel="noopener" class="block p-4 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                <div class="flex items-center justify-between">
                  <span class="font-semibold">OpenAI Privacy Policy</span>
                  <span class="text-slate-400">→</span>
                </div>
                <p class="text-sm text-slate-400 mt-1">https://openai.com/privacy</p>
              </a>

              <a href="https://www.anthropic.com/privacy" target="_blank" rel="noopener" class="block p-4 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                <div class="flex items-center justify-between">
                  <span class="font-semibold">Anthropic Privacy Policy</span>
                  <span class="text-slate-400">→</span>
                </div>
                <p class="text-sm text-slate-400 mt-1">https://www.anthropic.com/privacy</p>
              </a>

              <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="block p-4 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                <div class="flex items-center justify-between">
                  <span class="font-semibold">Google AI Privacy Policy</span>
                  <span class="text-slate-400">→</span>
                </div>
                <p class="text-sm text-slate-400 mt-1">https://policies.google.com/privacy</p>
              </a>

              <a href="https://groq.com/privacy-policy/" target="_blank" rel="noopener" class="block p-4 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                <div class="flex items-center justify-between">
                  <span class="font-semibold">Groq Privacy Policy</span>
                  <span class="text-slate-400">→</span>
                </div>
                <p class="text-sm text-slate-400 mt-1">https://groq.com/privacy-policy/</p>
              </a>
            </div>
          </div>

          <div class="bg-blue-500/10 border border-blue-500/30 p-4 rounded-lg">
            <p class="text-sm text-blue-200">
              Each provider has their own privacy policy governing how they handle your data.
            </p>
          </div>
        </section>

        <!-- Permissions Explanation -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            Permissions Explanation
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300 mb-4">The extension requires these permissions:</p>
            
            <div class="space-y-4">
              <div class="p-4 bg-white/5 rounded-lg">
                <h4 class="font-bold mb-2">storage</h4>
                <p class="text-sm text-slate-300">Store your settings and API keys locally in your browser</p>
              </div>

              <div class="p-4 bg-white/5 rounded-lg">
                <h4 class="font-bold mb-2">activeTab</h4>
                <p class="text-sm text-slate-300">Detect form fields on the current tab you're viewing</p>
              </div>

              <div class="p-4 bg-white/5 rounded-lg">
                <h4 class="font-bold mb-2">scripting</h4>
                <p class="text-sm text-slate-300">Inject UI elements (assistant buttons and chat interface) into web pages</p>
              </div>

              <div class="p-4 bg-white/5 rounded-lg">
                <h4 class="font-bold mb-2">sidePanel</h4>
                <p class="text-sm text-slate-300">Display the assistant interface in Chrome's side panel</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Your Control -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            Your Control
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300 mb-4">You have full control over:</p>
            
            <ul class="space-y-3 text-slate-300">
              <li class="flex gap-3">
                <span class="text-purple-400">✓</span>
                <div>Which AI provider to use</div>
              </li>
              <li class="flex gap-3">
                <span class="text-purple-400">✓</span>
                <div>What data to send (through context level settings)</div>
              </li>
              <li class="flex gap-3">
                <span class="text-purple-400">✓</span>
                <div>Which fields to exclude from AI assistance</div>
              </li>
              <li class="flex gap-3">
                <span class="text-purple-400">✓</span>
                <div>When to use the extension (enable/disable anytime)</div>
              </li>
            </ul>
          </div>
        </section>

        <!-- Data Retention -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M10 2v7.31"/><path d="M14 9.3V1.99"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><path d="M5.52 16h12.96"/></svg>
            </div>
            Data Retention
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300">
              Since we don't collect data, there's nothing to retain. <strong class="text-white">All data stays in your browser until you uninstall the extension.</strong>
            </p>
          </div>
        </section>

        <!-- Children's Privacy -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            Children's Privacy
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300">
              Sireno Assistant is not intended for children under 13. We do not knowingly collect data from children.
            </p>
          </div>
        </section>

        <!-- Changes to Privacy Policy -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/><path d="M9 13h6"/><path d="M9 17h6"/></svg>
            </div>
            Changes to Privacy Policy
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300">
              We may update this policy from time to time. Check the "Last Updated" date at the top of this page. Continued use of Sireno Assistant after changes constitutes acceptance of the updated policy.
            </p>
          </div>
        </section>

        <!-- Open Source -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            Open Source
          </h2>
          
          <div class="glass p-6 rounded-xl">
            <p class="text-slate-300 mb-4">
              Our code is open source and available for review. You can inspect exactly how we handle your data.
            </p>
            <a href="https://github.com/sergiocarracedo/sireno-assistant" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-medium">
              View Source Code on GitHub
              <span>→</span>
            </a>
          </div>
        </section>

        <!-- Contact -->
        <section class="mb-12">
          <div class="glass p-8 rounded-xl text-center">
            <h2 class="text-3xl font-bold mb-4">Questions About Privacy?</h2>
            <p class="text-slate-300 mb-6">
              We're happy to answer any privacy-related questions you may have.
            </p>
            <div class="space-y-3">
              <div>
                <span class="text-slate-400">Email:</span>
                <a href="mailto:hi@sergiocarracedo.es" class="text-purple-400 hover:text-purple-300 font-medium ml-2">
                  hi@sergiocarracedo.es
                </a>
              </div>
              <div>
                <span class="text-slate-400">GitHub:</span>
                <a href="https://github.com/sergiocarracedo/sireno-assistant" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 font-medium ml-2">
                  sergiocarracedo/sireno-assistant
                </a>
              </div>
            </div>
          </div>
        </section>

      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 border-t border-slate-800 py-12">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex items-center gap-3">
            <Logo class="w-8 h-8" color="#fff" />
            <span class="text-lg font-semibold">Sireno Assistant</span>
          </div>
          
          <div class="flex flex-wrap justify-center gap-6 text-sm">
            <a href="/getting-started" class="hover:text-purple-400 transition-colors">Getting Started</a>
            <a href="/privacy" class="text-purple-400">Privacy</a>
            <a href="https://github.com/sergiocarracedo/sireno-assistant" target="_blank" rel="noopener" class="hover:text-purple-400 transition-colors">GitHub</a>
            <a href="https://chromewebstore.google.com/detail/ppnecnomfnadhbcpacgkfldiapoejogo" target="_blank" rel="noopener" class="hover:text-purple-400 transition-colors">Chrome Web Store</a>
          </div>
          
          <div class="text-sm text-slate-400">
            Made with ❤️ by Sergio Carracedo
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
