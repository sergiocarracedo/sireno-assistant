---
import '../styles/global.css';
import '../styles/custom.css';
import Logo from '../components/Logo.astro';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Learn how to install and use Sireno Assistant. Step-by-step guide to set up your AI-powered web assistant." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Getting Started - Sireno Assistant</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-slate-950 text-white antialiased">
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/10">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <Logo class="w-10 h-10" color="#fff" />
            <span class="text-xl font-bold">Sireno Assistant</span>
          </a>
          <div class="hidden md:flex items-center gap-6">
            <a href="/getting-started" class="text-purple-400">Docs</a>
            <a href="https://github.com/sergiocarracedo/sireno-assistant" target="_blank" rel="noopener" class="hover:text-purple-400 transition-colors">GitHub</a>
            <a href="https://chromewebstore.google.com/detail/ppnecnomfnadhbcpacgkfldiapoejogo" target="_blank" rel="noopener" class="bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 px-6 py-2 rounded-lg font-medium transition-all border-2 border-white">
              Install Extension
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="pt-24 pb-16">
      <div class="container mx-auto px-4 max-w-4xl">
        
        <!-- Hero -->
        <div class="mb-12">
          <h1 class="text-5xl font-bold mb-4 gradient-text">Getting Started</h1>
          <p class="text-xl text-slate-300">
            Everything you need to know to start using Sireno Assistant
          </p>
        </div>

        <!-- Installation -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-12 h-12 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </div>
            Installation
          </h2>
          
          <div class="glass p-6 rounded-xl mb-6">
            <ol class="space-y-4 text-slate-300">
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">1.</span>
                <div>
                  <p>Visit the <a href="https://chromewebstore.google.com/detail/ppnecnomfnadhbcpacgkfldiapoejogo" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 underline">Chrome Web Store page</a></p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">2.</span>
                <div>
                  <p>Click <strong>"Add to Chrome"</strong></p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">3.</span>
                <div>
                  <p>Confirm the installation by clicking <strong>"Add extension"</strong> in the popup</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">4.</span>
                <div>
                  <p>The Sireno Assistant icon will appear in your Chrome toolbar</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="bg-blue-500/10 border border-blue-500/30 p-4 rounded-lg flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400 mt-0.5 flex-shrink-0"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            <p class="text-sm text-blue-200">
              <strong>Tip:</strong> Pin the extension to your toolbar by clicking the puzzle icon in Chrome and selecting the pin icon next to Sireno Assistant.
            </p>
          </div>
        </section>

        <!-- Configuration -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-12 h-12 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            Configuration
          </h2>
          
          <div class="glass p-6 rounded-xl mb-6">
            <h3 class="text-xl font-bold mb-4">Adding Your API Key</h3>
            <ol class="space-y-4 text-slate-300">
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">1.</span>
                <div>
                  <p>Click the Sireno Assistant icon in your toolbar</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">2.</span>
                <div>
                  <p>Click the <strong>Settings</strong> icon in the side panel</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">3.</span>
                <div>
                  <p>Choose your AI provider from the dropdown menu</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">4.</span>
                <div>
                  <p>Enter your API key for the selected provider</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="font-bold text-purple-400 min-w-[2rem]">5.</span>
                <div>
                  <p>(Optional) Select a specific model if you want to override the default</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="space-y-4 mb-6">
            <h3 class="text-xl font-bold">Where to Get API Keys</h3>
            
            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                OpenAI
              </h4>
              <p class="text-sm text-slate-300 mb-2">Visit <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 underline">platform.openai.com/api-keys</a></p>
              <p class="text-xs text-slate-400">Requires payment method. Pay-as-you-go pricing.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                Anthropic
              </h4>
              <p class="text-sm text-slate-300 mb-2">Visit <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 underline">console.anthropic.com/settings/keys</a></p>
              <p class="text-xs text-slate-400">Requires payment method. Pay-as-you-go pricing.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                Google AI Studio
              </h4>
              <p class="text-sm text-slate-300 mb-2">Visit <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 underline">aistudio.google.com/app/apikey</a></p>
              <p class="text-xs text-slate-400">Free tier available with generous rate limits.</p>
            </div>

            <div class="glass p-4 rounded-lg border-2 border-green-500/30">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                Groq
                <span class="text-xs font-bold text-green-400 bg-green-500/20 px-2 py-1 rounded">FREE</span>
              </h4>
              <p class="text-sm text-slate-300 mb-2">Visit <a href="https://console.groq.com/keys" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 underline">console.groq.com/keys</a></p>
              <p class="text-xs text-slate-400">Free tier with no credit card required. Fast inference.</p>
            </div>
          </div>

          <div class="bg-green-500/10 border border-green-500/30 p-4 rounded-lg">
            <p class="text-sm text-green-200 flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 mt-0.5 flex-shrink-0"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              <span><strong>Recommended for beginners:</strong> Start with Groq's free tier to try Sireno Assistant without any cost!</span>
            </p>
          </div>
        </section>

        <!-- Basic Usage -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M4.5 16.5c-1.5 1.25-2 5-2 5s3.75-.5 5-2c.625-.625 1-1.5 1-2.5a2 2 0 0 0-4 0z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
            </div>
            Basic Usage
          </h2>
          
          <div class="space-y-6">
            <div class="glass p-6 rounded-xl">
              <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                Inline Chat
              </h3>
              <ol class="space-y-3 text-slate-300">
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">1.</span>
                  <div>Right-click any text field on any website</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">2.</span>
                  <div>Select <strong>"Open Sireno Chat"</strong> from the context menu</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">3.</span>
                  <div>Type your message or question and press Enter</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">4.</span>
                  <div>The AI will respond in real-time with streaming</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">5.</span>
                  <div>Click <strong>"Apply"</strong> to insert the response into the field</div>
                </li>
              </ol>
            </div>

            <div class="glass p-6 rounded-xl">
              <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Using Skills
              </h3>
              <p class="text-slate-300 mb-4">Skills are pre-defined prompts for common tasks:</p>
              <ol class="space-y-3 text-slate-300">
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">1.</span>
                  <div>Select text in any field</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">2.</span>
                  <div>Right-click and choose <strong>"Sireno Skills"</strong></div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">3.</span>
                  <div>Select a skill (Fix Grammar, Make Formal, Translate, etc.)</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">4.</span>
                  <div>The AI will process your text and show the result</div>
                </li>
              </ol>
            </div>

            <div class="glass p-6 rounded-xl border-2 border-purple-500/30">
              <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><path d="M14 15h6"/><path d="M14 19h6"/></svg>
                Side Panel Transfer <span class="text-xs font-bold text-purple-400 bg-purple-500/20 px-2 py-1 rounded">NEW v0.2.1</span>
              </h3>
              <p class="text-slate-300 mb-4">Transfer conversations to the side panel for more space:</p>
              <ol class="space-y-3 text-slate-300">
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">1.</span>
                  <div>Start a conversation in inline chat</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">2.</span>
                  <div>Click the <strong>"Transfer to Side Panel"</strong> button (↗️)</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">3.</span>
                  <div>The side panel opens with your message pre-filled</div>
                </li>
                <li class="flex gap-4">
                  <span class="font-bold text-purple-400 min-w-[2rem]">4.</span>
                  <div>Continue the conversation with more space and context</div>
                </li>
              </ol>
            </div>
          </div>
        </section>

        <!-- Tips & Tricks -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            </div>
            Tips & Tricks
          </h2>
          
          <div class="space-y-4">
            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                Works on Any Website
              </h4>
              <p class="text-sm text-slate-300">Sireno detects text fields dynamically, even on single-page apps with dynamic content.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
                Switch Providers Anytime
              </h4>
              <p class="text-sm text-slate-300">You can change AI providers in settings at any time. Your API keys are saved separately.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Streaming Responses
              </h4>
              <p class="text-sm text-slate-300">All providers support streaming, so you see responses in real-time as they're generated.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Privacy-First
              </h4>
              <p class="text-sm text-slate-300">Your API keys never leave your browser. Direct communication with AI providers only.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
                Custom Instructions
              </h4>
              <p class="text-sm text-slate-300">Use the inline chat for custom instructions beyond the predefined skills.</p>
            </div>
          </div>
        </section>

        <!-- Troubleshooting -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center bg-purple-500/20 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            Troubleshooting
          </h2>
          
          <div class="space-y-4">
            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
                "Invalid API Key" error
              </h4>
              <p class="text-sm text-slate-300 mb-2">Make sure you've copied the entire API key correctly from your provider's dashboard.</p>
              <p class="text-xs text-slate-400">Check for extra spaces or missing characters.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-yellow-400"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                "Rate limit exceeded" error
              </h4>
              <p class="text-sm text-slate-300 mb-2">You've exceeded your API provider's rate limits. Wait a few moments and try again.</p>
              <p class="text-xs text-slate-400">Consider upgrading your plan with the provider if this happens frequently.</p>
            </div>

            <div class="glass p-4 rounded-lg">
              <h4 class="font-bold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
                Extension not detecting fields
              </h4>
              <p class="text-sm text-slate-300 mb-2">Try refreshing the page. Sireno should detect fields automatically after page load.</p>
              <p class="text-xs text-slate-400">If issues persist, report on GitHub.</p>
            </div>
          </div>
        </section>

        <!-- Support -->
