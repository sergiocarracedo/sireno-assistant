---
// Hero background shader using "Subtle Liquid 1" preset from shaders.com
// Preset ID: be2ff117-8f59-4406-9e98-295c791ff376
---

<canvas
  id="hero-shader-canvas"
  aria-hidden="true"
  style="position:absolute;inset:0;width:100%;height:100%;display:block;pointer-events:none;"
></canvas>

<script>
  import { shaderRenderer, createUniformsMap } from 'shaders/core'
  import { vec4 } from 'three/tsl'
  import LinearGradient from 'shaders/core/LinearGradient'
  import Blob from 'shaders/core/Blob'
  import DotGrid from 'shaders/core/DotGrid'
  import Liquify from 'shaders/core/Liquify'
  import FilmGrain from 'shaders/core/FilmGrain'

  async function initShader() {
    const canvas = document.getElementById('hero-shader-canvas') as HTMLCanvasElement
    if (!canvas) {
      console.error('[HeroShader] canvas not found')
      return
    }

    const renderer = shaderRenderer()
    await renderer.initialize({ canvas, colorSpace: 'p3-linear' })

    // Note: node IDs must use underscores — hyphens become invalid GLSL uniform names
    // Note: ALL props must be passed explicitly — createUniformsMap calls transform(undefined)
    //       before falling back to defaults, which throws for color/angle/position transforms
    const rootId = 'hero_root'
    renderer.registerNode(
      rootId,
      ({ childNode }: { childNode: any }) => childNode || vec4(0, 0, 0, 0),
      null,
      null,
      {}
    )

    // LinearGradient — purple/magenta to blue base layer
    const lgId = 'hero_lg'
    const lgUniforms = createUniformsMap(
      LinearGradient,
      {
        colorA: '#be04cf', // Purple/Magenta
        colorB: '#0000f7', // Blue
        colorSpace: 'oklch',
        edges: 'mirror',
        start: { x: 0.23252032520325203, y: 0.6980126467931346 },
        end: { x: 0.6731707317073171, y: 0.277416440831075 },
        angle: 0,
      },
      lgId
    )
    renderer.registerNode(
      lgId,
      LinearGradient.fragmentNode,
      rootId,
      { blendMode: 'normal', visible: true, renderOrder: 0 },
      lgUniforms,
      LinearGradient
    )

    // Blob — animated purple/magenta blobs with yellow highlight
    const blobId = 'hero_blob'
    const blobUniforms = createUniformsMap(
      Blob,
      {
        colorA: '#7835ff', // Purple
        colorB: '#cd0ced', // Magenta
        colorSpace: 'oklch',
        size: 1,
        deformation: 0.9,
        softness: 2,
        speed: 1,
        highlightIntensity: 0.5,
        highlightX: 0.3,
        highlightY: -0.3,
        highlightZ: 0.4,
        highlightColor: '#ffe11a', // Yellow
        seed: 1,
        center: { x: 0.5, y: 0.5 },
      },
      blobId
    )
    renderer.registerNode(
      blobId,
      Blob.fragmentNode,
      rootId,
      { blendMode: 'normal-oklch', visible: true, renderOrder: 1 },
      blobUniforms,
      Blob
    )

    // DotGrid — subtle white dot texture overlay
    const dotId = 'hero_dotgrid'
    const dotUniforms = createUniformsMap(
      DotGrid,
      { color: '#ffffff', density: 40, dotSize: 0.05, twinkle: 0 },
      dotId
    )
    renderer.registerNode(
      dotId,
      DotGrid.fragmentNode,
      rootId,
      { blendMode: 'linearDodge', visible: true, renderOrder: 2 },
      dotUniforms,
      DotGrid
    )

    // Liquify — warping distortion (edges must be explicit — compileTime prop)
    const liquifyId = 'hero_liquify'
    const liquifyUniforms = createUniformsMap(
      Liquify,
      { intensity: 2, decay: 1, radius: 2, edges: 'mirror' },
      liquifyId
    )
    renderer.registerNode(
      liquifyId,
      Liquify.fragmentNode,
      rootId,
      { blendMode: 'normal', visible: true, renderOrder: 3 },
      liquifyUniforms,
      Liquify
    )

    // FilmGrain — subtle noise
    const grainId = 'hero_grain'
    const grainUniforms = createUniformsMap(FilmGrain, { strength: 0.09 }, grainId)
    renderer.registerNode(
      grainId,
      FilmGrain.fragmentNode,
      rootId,
      { blendMode: 'normal', visible: true, renderOrder: 4 },
      grainUniforms,
      FilmGrain
    )

    renderer.startAnimation()
    console.log('[HeroShader] animation started')
  }

  initShader().catch((err) => console.error('[HeroShader] init failed:', err))
</script>
